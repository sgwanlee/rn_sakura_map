{
  "expo": {
    "name": "YOUR APP TITLE",
    "slug": "your-app-title",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6F1FFC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.house201.yourapp",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "locales": {
      "en": "./config/i18n/en.json",
      "ko": "./config/i18n/ko.json",
      "ja": "./config/i18n/ja.json"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.house201.yourapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "0771651f-d21f-40b9-b945-df066c542e97"
      }
    },
    "plugins": [
      "expo-splash-screen",
      "expo-asset",
      "expo-audio",
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-2507125479501117~7608212419",
          "androidAppId": "ca-app-pub-2507125479501117~6600292620"
        }
      ],
      "expo-font",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "buildReactNativeFromSource": true,
            "deploymentTarget": "15.1"
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ]
  }
}
