{
  "expo": {
    "name": "벚꽃명소 지도",
    "slug": "sakura-map",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6F1FFC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.house201.sakuramap",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleAllowMixedLocalizations": true,
        "NSLocationWhenInUseUsageDescription": "내 주변 벚꽃 명소를 찾기 위해 위치 정보가 필요합니다."
      }
    },
    "locales": {
      "en": "./config/i18n/en.json",
      "ko": "./config/i18n/ko.json",
      "ja": "./config/i18n/ja.json"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "package": "com.house201.sakuramap"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ef729f0a-e72c-4f56-b010-e5fa6d67978f"
      }
    },
    "plugins": [
      "expo-splash-screen",
      "expo-asset",
      "expo-audio",
      [
        "@mj-studio/react-native-naver-map",
        {
          "client_id": "omyh26vpam"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-2507125479501117~7608212419",
          "androidAppId": "ca-app-pub-2507125479501117~6600292620"
        }
      ],
      "expo-font",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "buildReactNativeFromSource": true,
            "deploymentTarget": "15.1"
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "extraMavenRepos": [
              "https://repository.map.naver.com/archive/maven"
            ]
          }
        }
      ]
    ],
    "owner": "sgwanlee"
  }
}